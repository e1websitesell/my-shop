rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- হেল্পার ফাংশন ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ---------- products ----------
    // সবাই পড়তে পারবে, লিখতে পারবে শুধু অ্যাডমিন
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();

      // রিভিউ: যে কেউ লগইন করা থাকলে রিভিউ লিখতে পারবে,
      // ডিলিট/এডিট শুধু নিজের রিভিউ বা অ্যাডমিন
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isOwner(resource.data.userId) || isAdmin();
      }
    }

    // ---------- categories ----------
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- settings (থিম, ডেলিভারি জোন, শপ ইনফো) ----------
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- coupons ----------
    // ডকুমেন্ট আইডি = কুপন কোড নিজেই (যেমন coupons/SAVE10)
    // এতে ইউজার নির্দিষ্ট কোড "get" করতে পারবে (ভ্যালিডেশনের জন্য)
    // কিন্তু পুরো কালেকশন "list" করে সব কুপন কোড দেখে ফেলতে পারবে না
    match /coupons/{couponCode} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // ---------- users ----------
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /cart/{cartItemId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ---------- admins ----------
    // ক্লায়েন্ট থেকে write সম্পূর্ণ ব্লকড — Firebase Console থেকে ম্যানুয়ালি অ্যাড করতে হবে
    match /admins/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // ---------- orders ----------
    // লগইন ছাড়াও অর্ডার লগ হতে পারবে (পেমেন্ট গেটওয়ে নাই, তাই গেস্ট চেকআউট দরকার)
    match /orders/{orderId} {
      allow create: if request.resource.data.status == "pending"
                    && request.resource.data.items is list
                    && request.resource.data.totalAmount is number;
      allow read: if isAdmin() ||
                    (isSignedIn() && resource.data.customerUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}
